# SafeDXB — Production API Keys
# Copy to .env and fill in your keys (never commit .env)

# 1. GDELT Cloud (primary live news source — conflict/security clusters)
# Sign up: https://gdeltcloud.com/auth/sign-up — Analyst or Professional plan required
# Use VITE_GDELT_API_KEY for local dev; add GDELT_API_KEY to Vercel env for production (keeps key server-side)
VITE_GDELT_API_KEY=

# 2. NewsAPI (fallback for Latest News)
# Register: https://newsapi.org/register — free tier: 100 requests/day
VITE_NEWS_API_KEY=

# 3. Anthropic Claude (required for AI bullet summaries)
# Get key: https://console.anthropic.com — paid, usage-based
VITE_ANTHROPIC_API_KEY=

# Note: GDELT Project (strike map) and ipapi/OpenStreetMap (location) need no keys
