# SafeDXB — Production API Keys
# Copy to .env and fill in your keys (never commit .env)

# 1. NewsAPI (required for Latest News articles)
# Register: https://newsapi.org/register — free tier: 100 requests/day
VITE_NEWS_API_KEY=

# 2. Anthropic Claude (required for AI bullet summaries)
# Get key: https://console.anthropic.com — paid, usage-based
VITE_ANTHROPIC_API_KEY=

# Note: GDELT (strike map) and ipapi/OpenStreetMap (location) need no keys
